<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_vehicle_import_wizard" model="ir.ui.view">
        <field name="name">vehicle.import.wizard.form</field>
        <field name="model">vehicle.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Vehicles from CSV">
                <sheet>
                    <group>
                        <field name="csv_file"
                               filename="csv_filename"
                               placeholder="Select CSV file..."
                               widget="binary"
                               required="1"/>
                        <field name="csv_filename" invisible="1"/>
                    </group>

                    <group string="Import Log" col="1">
                        <field name="import_log"
                               widget="text"
                               readonly="1"
                               nolabel="1"/>
                    </group>

                    <footer>
                        <button name="action_import"
                                string="Import CSV"
                                type="object"
                                class="btn-primary"/>
                        <button name="action_download_template"
                                string="Download Template"
                                type="object"
                                class="btn-secondary"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_vehicle_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Vehicles from CSV</field>
        <field name="res_model">vehicle.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_vehicle_master"/>
        <field name="binding_view_types">list,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_vehicle_import"
              name="Import Vehicles"
              parent="menu_vehicle_root"
              action="action_vehicle_import_wizard"
              sequence="60"/>
</odoo>