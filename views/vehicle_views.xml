    <record id="view_vehicle_brand_form" model="ir.ui.view">
        <field name="name">vehicle.brand.form</field>
        <field name="model">vehicle.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar" options="{'preview_image': 'logo'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Toyota"/></h1>
                    </div>
                    <notebook>
                        <page string="Models &amp; Configuration">
                            <field name="model_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="variant_ids" widget="many2many_tags" string="Available Variants"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="name"/>
                                    </group>
                                    <notebook>
                                        <page string="Chassis Codes">
                                            <field name="chassis_ids">
                                                <tree editable="bottom">
                                                    <field name="name"/>
                                                </tree>
                                            </field>
                                        </page>
                                        <page string="Body Styles">
                                            <field name="body_style_ids">
                                                <tree editable="bottom">
                                                    <field name="name"/>
                                                </tree>
                                            </field>
                                        </page>
                                        <page string="Variants">
                                            <field name="variant_ids">
                                                <tree editable="bottom">
                                                    <field name="name"/>
                                                    <field name="year_from"/>
                                                    <field name="year_to"/>
                                                </tree>
                                            </field>
                                        </page>
                                    </notebook>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="vehicle_brand_view_kanban" model="ir.ui.view">
        <field name="name">vehicle.brand.kanban</field>
        <field name="model">vehicle.brand</field>
        <field name="arch" type="xml">
            <kanban default_order="name">
                <field name="name"/><field name="logo"/><field name="model_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_vignette oe_semantic_html_override oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <field name="logo" widget="image" class="o_image_64_max"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><t t-esc="record.model_count.value"/> Models</div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_vehicle_master" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">vehicle.master</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_vehicle_master_search"/>
    </record>


    <record id="action_vehicle_brand" model="ir.actions.act_window">
        <field name="name">Vehicle Brands</field>
        <field name="res_model">vehicle.brand</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>


    <menuitem id="menu_vehicle_root" name="Vehicle Master" web_icon="vehicle_master_vin,static/description/icon.png"/>
    <menuitem id="menu_vehicle" name="Vehicles" parent="menu_vehicle_root" action="action_vehicle" sequence="10"/>
    <menuitem id="menu_vehicle_brand" name="Brands" parent="menu_vehicle_root" action="action_vehicle_brand" sequence="20"/>

</odoo>