<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_vehicle_master_search" model="ir.ui.view">
        <field name="name">vehicle.master.search</field>
        <field name="model">vehicle.master</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name" string="Vehicle, Owner, Plate, VIN or Master Number"
                       filter_domain="['|', '|', '|', '|',
                                   ('name', 'ilike', self),
                                   ('partner_id.name', 'ilike', self),
                                   ('license_plate', 'ilike', self),
                                   ('vin', 'ilike', self),
                                   ('master_number', 'ilike', self)]"/>

                <field name="partner_id" string="Owner"/>
                <field name="license_plate"/>
                <field name="vin" string="VIN/Chassis"/>
                <field name="master_number" string="Master Number"/>
                <field name="brand_id"/>
                <field name="model_id"/>

                <separator/>

                <group expand="0" string="Group By">
                    <filter string="Owner" name="group_partner" context="{'group_by':'partner_id'}"/>
                    <filter string="Brand" name="group_brand" context="{'group_by':'brand_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by':'model_id'}"/>
                </group>
            </search>
        </field>
    </record>



    <record id="view_partner_form_inherit_dob" model="ir.ui.view">
        <field name="name">res.partner.form.dob</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="date_of_birth"/>
                <field name="insurance_company"/>
            </xpath>
            <xpath expr="//field[@name='email']" position="before">
                <field name="whatsapp_no" widget="phone"/>
            </xpath>
            <xpath expr="//field[@name='child_ids']//form//field[@name='email']" position="before">
                <field name="whatsapp_no" widget="phone"/>
            </xpath>
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="Vehicle Info" name="vehicle_info_tab">
                    <field name="vehicle_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="year"/>
                            <field name="license_plate"/>
                            <field name="vin"/>
                            <field name="color_id"/>
                            <field name="fuel_type"/>
                        </tree>
                        <form>
                            <sheet>
                                <group>
                                    <field name="brand_id"/>
                                    <field name="model_id"/>
                                    <field name="year"/>
                                    <field name="license_plate"/>
                                    <field name="vin"/>
                                    <field name="color_id"/>
                                    <field name="fuel_type"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_vehicle_tree" model="ir.ui.view">
        <field name="name">vehicle.master.tree</field>
        <field name="model">vehicle.master</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="year"/>
                <field name="license_plate"/>
                <field name="vin"/>
                <field name="master_number" string="Master Number"/>
                <field name="mileage"/>
                <field name="your_ref" optional="hide"/>
                <field name="our_ref" optional="hide"/>
            </tree>
        </field>
    </record>



    <record id="view_vehicle_form" model="ir.ui.view">
        <field name="name">vehicle.master.form</field>
        <field name="model">vehicle.master</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>


                    <div class="oe_button_box" name="button_box">

                        <button name="action_view_services"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-wrench">
                            <field name="service_ids" widget="statinfo" string="Services"/>
                        </button>

                        <button name="action_view_rentals"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-car">
                            <field name="rental_ids" widget="statinfo" string="Rentals"/>
                        </button>



                    </div>

                    <div class="oe_title">
                        <label for="name" string="Vehicle Display Name"/>
                        <h1>
                            <field name="name" placeholder="Vehicle Name"/>
                        </h1>
                    </div>
                    <!-- BASIC VEHICLE DATA -->
                    <group string="Vehicle Information">
                        <group>
                            <field name="vehicle_type" widget="radio" options="{'horizontal': true}"/>

                            <field name="partner_id" string="Owner"/>
                            <field name="license_plate"/>
                            <field name="brand_id"/>
                            <field name="model_id"/>
                            <field name="variant_id"/>
                            <field name="chassis_id"/>
                            <field name="body_style_id"/>
                            <field name="drive_type"/>
                            <field name="steering_location"/>
                            <field name="brake_system"/>
                            <field name="series"/>


                            <field name="owner_last_name"/>
                            <field name="owner_first_name"/>
                            <field name="owner_street"/>
                            <field name="owner_zip"/>
                            <field name="owner_city"/>
                            <field name="owner_ref_uid"/>
                            <field name="owner_dob"/>
                            <field name="place_of_origin"/>
                            <field name="insurance_company"/>
                            <field name="cantonal_notes"/>
                            <field name="official_instructions"/>
                            <field name="body_type_code"/>
                            <field name="seats_total"/>
                            <field name="weight_empty"/>
                            <field name="towing_capacity"/>
                            <field name="payload"/>
                            <field name="total_weight"/>
                            <field name="roof_load"/>
                            <field name="displacement_cc"/>
                            <field name="emission_code"/>
                            <field name="power_weight_ratio"/>







                        </group>

                        <group>

                            <field name="year"/>
                            <field name="color_id"/>
                            <field name="color"/>
                            <field name="fuel_type"/>
                            <field name="transmission"/>
                            <field name="engine"/>
                            <field name="power_kw"/>
                            <!--                            <field name="certificate_scan"/>-->
                            <field name="certificate_image"/>
                            <field name="certificate_filename"/>
                        </group>

                    </group>


                    <header>

                        <button name="action_scan_certificate_with_gemini"
                                string="Scan with Gemini AI"
                                type="object"
                                class="oe_highlight"
                                icon="fa-qrcode"/>


                        <!-- ONLY ONE SCAN BUTTON -->
                        <!--
                                                <button name="action_scan_certificate"
                                                        type="object"
                                                        string="Scan Certificate"
                                                        class="btn-primary"
                                                        invisible="not certificate_image"/>
                        -->

                        <button name="action_fetch_vehicle_data"
                                type="object"
                                string="Decode VIN"
                                class="btn-secondary"
                                invisible="not vin"/>
                    </header>
                    <group>

                        <group string="Financial Info">
                            <field name="purchase_price"/>
                            <field name="sale_price"/>
                            <field name="total_service_cost" readonly="1"/>
                            <field name="profit" readonly="1"/>
                        </group>

                        <group>

                            <label for="vin"/>
                            <div class="o_row">
                                <field name="vin" placeholder="17-digit VIN"/>
                                <button name="action_fetch_vehicle_data"
                                        type="object"
                                        string="Fetch"
                                        class="btn-primary"
                                        icon="fa-refresh"
                                        invisible="not vin"/>
                            </div>

                            <!--                            <field name="vin" />-->
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="year"/>
                            <field name="engine"/>
                            <field name="fuel_type"/>
                            <field name="power_kw"/>
                            <field name="transmission"/>
                            <field name="vehicle_type"/>
                            <field name="vehicle_type_code"/>
                        </group>
                        <group>

                            <field name="body_class"/>
                            <field name="doors"/>
                            <field name="engine_cylinders"/>
                            <field name="engine_displacement"/>
                            <field name="manufacturer"/>
                            <field name="plant_country"/>
                            <field name="plant_city"/>
                            <field name="trim"/>
                        </group>
                    </group>




                    <!-- SWISS VEHICLE DATA -->
                    <group string="Swiss Registration Data">
                        <group>
                            <!--                            <field name="license_plate"/>-->
                            <field name="master_number" string="Master Number"/>
                            <field name="issue_place_id"/>
                            <!--                            <field name="issue_date"/>-->
                            <field name="type_code"/>
                        </group>
                        <group>
                            <field name="first_registration"/>
                            <field name="mileage"/>
                            <field name="last_service_date"/>
                        </group>
                    </group>


                    <!-- REFERENCES -->
                    <group string="References">
                        <group>
                            <field name="your_ref"/>
                        </group>
                        <group>
                            <field name="our_ref"/>
                        </group>
                    </group>


                    <!-- PHOTOS -->
                    <notebook>

                        <page string="Vehicle Condition Photos"
                              name="vehicle_photos">
                            <div class="row w-100 m-0 pt-3">
                                <!-- FRONT -->
                                <div class="col-md-4 d-flex flex-column align-items-center mb-4">
                                    <field name="image_front"
                                           widget="image"
                                           options='{"size":[256,256]}'
                                           style="width:256px;height:256px;border:1px solid #dee2e6;border-radius:4px;background:#f8f9fa;object-fit:cover;"/>
                                    <div class="mt-2 fw-bold text-dark">
                                        Front View
                                    </div>
                                </div>


                                <!-- BACK -->

                                <div class="col-md-4 d-flex flex-column align-items-center mb-4">
                                    <field name="image_back"
                                           widget="image"
                                           options='{"size":[256,256]}'
                                           style="width:256px;height:256px;border:1px solid #dee2e6;border-radius:4px;background:#f8f9fa;object-fit:cover;"/>
                                    <div class="mt-2 fw-bold text-dark">
                                        Back View
                                    </div>
                                </div>

                                <!-- SIDE -->

                                <div class="col-md-4 d-flex flex-column align-items-center mb-4">

                                    <field name="image_side"
                                           widget="image"
                                           options='{"size":[256,256]}'
                                           style="width:256px;height:256px;border:1px solid #dee2e6;border-radius:4px;background:#f8f9fa;object-fit:cover;"/>

                                    <div class="mt-2 fw-bold text-dark">
                                        Side View
                                    </div>

                                </div>

                            </div>

                        </page>

                        <page string="Service History">
                            <field name="service_ids">
                                <tree editable="bottom">
                                    <field name="service_date"/>
                                    <field name="description"/>
                                    <field name="cost"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Rental History">
                            <field name="rental_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="total_amount"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>





    <record id="action_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">vehicle.master</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_vehicle_brand_tree" model="ir.ui.view">
        <field name="name">vehicle.brand.tree</field>
        <field name="model">vehicle.brand</field>
        <field name="arch" type="xml">
            <tree>
                <field name="logo" widget="image" options="{'size': [50, 50]}"/>
                <field name="name"/>
                <field name="model_count"/>
            </tree>
        </field>
    </record>

