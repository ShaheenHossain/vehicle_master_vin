<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ==================== SELL VEHICLES ==================== -->

    <!-- Tree View for Sell Vehicles -->
    <record id="view_vehicle_sell_tree" model="ir.ui.view">
        <field name="name">vehicle.sell.tree</field>
        <field name="model">vehicle.master</field>
        <field name="arch" type="xml">
            <tree string="Vehicles for Sale" create="1" edit="1" delete="1">
                <field name="name" string="Vehicle Name"/>
                <field name="brand_id" string="Brand"/>
                <field name="model_id" string="Model"/>
                <field name="year" string="Year"/>
                <field name="license_plate" string="License Plate"/>
                <field name="vin" string="VIN"/>
                <field name="master_number" string="Master Number"/>
                <field name="color" string="Color"/>
                <field name="mileage" string="Mileage"/>
                <field name="fuel_type" string="Fuel"/>
                <field name="transmission" string="Transmission"/>
                <field name="purchase_price" string="Purchase Price"/>
                <field name="sale_price" string="Sale Price"/>
                <field name="profit" string="Profit"/>
            </tree>
        </field>
    </record>

    <!-- Form View for Sell Vehicles (NO OWNER INFO) -->

        <record id="view_vehicle_sell_form" model="ir.ui.view">
        <field name="name">vehicle.master.form</field>
        <field name="model">vehicle.master</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <header>
                        <button name="action_scan_certificate_with_gemini"
                                string="Scan with AI"
                                type="object"
                                class="oe_highlight"
                                icon="fa-qrcode"/>

                    </header>

                    <div class="oe_button_box" name="button_box">

                        <button name="action_view_services"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-wrench">
                            <field name="service_ids" widget="statinfo" string="Services"/>
                        </button>

                        <button name="action_view_rentals"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-car">
                            <field name="rental_ids" widget="statinfo" string="Rentals"/>
                        </button>



                    </div>

                    <div class="oe_title">
                        <label for="name" string="Vehicle Display Name"/>
                        <h1>
                            <field name="name" placeholder="Vehicle Name"/>
                        </h1>
                    </div>
                    <!-- BASIC VEHICLE DATA -->
                    <group string="Vehicle Information">
                        <group>
                            <field name="certificate_image"/>
                            <!--                            <field name="certificate_filename"/>-->

                            <label for="vin"/>
                            <div class="o_row">
                                <field name="vin" placeholder="17-digit VIN"/>
                                <!--                                <button name="action_fetch_vehicle_data"
                                                                        type="object"
                                                                        string="Fetch"
                                                                        class="btn-primary"
                                                                        icon="fa-refresh"
                                                                        invisible="not vin"/>-->
                            </div>


                            <field name="license_plate"/>
                            <field name="master_number" string="Master Number"/>

                            <field name="color"/>
                            <field name="seats_total"/>
                            <field name="approval_type"/>
                            <field name="displacement_cc"/>
                            <field name="power_kw"/>
                            <field name="place_date_issue"/>
                            <field name="vehicle_category"/>
                            <field name="vehicle_category_code"/>
                            <field name="body_type"/>
                            <field name="body_type_code"/>
                            <!--                            <field name="brand"/>
                                                        <field name="model"/>-->
                            <field name="model_code"/>

                            <field name="vehicle_type"/>
                            <field name="last_inspection"/>

                            <field name="brand_id" store="true"/>
                            <field name="model_id"/>
                            <field name="variant_id"/>
                            <field name="chassis_id"/>
                            <field name="body_style_id"/>
                            <field name="drive_type"/>
                            <field name="steering_location"/>
                            <field name="brake_system"/>
                            <field name="series"/>

                            <field name="place_of_origin"/>
                            <field name="insurance_company"/>
                            <field name="cantonal_notes"/>
                            <field name="official_instructions"/>
                            <field name="body_type_code"/>
                            <field name="seats_total"/>
                            <field name="weight_empty"/>
                            <field name="towing_capacity"/>
                            <field name="payload"/>
                            <field name="total_weight"/>
                            <field name="roof_load"/>
                            <field name="displacement_cc"/>
                            <field name="emission_code"/>
                            <field name="power_weight_ratio"/>
                            <field name="year"/>
                            <field name="fuel_type"/>
                            <field name="transmission"/>
                            <field name="engine"/>
                            <field name="power_kw"/>
                            <!--                            <field name="certificate_scan"/>-->

                        </group>

                        <group string="Owner Information">
                            <field name="owner_id" string="Owner ID No."/>
                            <field name="owner_first_name"/>
                            <field name="owner_last_name"/>

                            <field name="partner_id" string="Owner Name"/>
                            <!--                            <field name="owner_name" placeholder="Last Name then First Name (e.g., Egli Marcel)"/>-->

                            <field name="street"/>
                            <field name="zip"/>
                            <field name="city"/>
                            <field name="owner_ref_uid"/>
                            <field name="owner_dob"/>
                            <field name="telephone"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="fax"/>
                            <field name="email"/>
                        </group>
                    </group>

                    <header>




                        <!-- ONLY ONE SCAN BUTTON -->
                        <!--
                                                <button name="action_scan_certificate"
                                                        type="object"
                                                        string="Scan Certificate"
                                                        class="btn-primary"
                                                        invisible="not certificate_image"/>
                        -->

                        <!--                        <button name="action_fetch_vehicle_data"
                                                        type="object"
                                                        string="Decode VIN"
                                                        class="btn-secondary"
                                                        invisible="not vin"/>-->
                    </header>
                    <group>

                        <group string="Financial Info">
                            <field name="purchase_price"/>
                            <field name="sale_price"/>
                            <field name="total_service_cost" readonly="1"/>
                            <field name="profit" readonly="1"/>
                        </group>

                        <group>



                            <!--                            <field name="vin" />-->
                            <!--                            <field name="brand"/>-->
                            <!--                            <field name="model"/>-->
                            <!--                            <field name="year"/>-->
                            <field name="engine"/>
                            <field name="fuel_type"/>
                            <field name="power_kw"/>
                            <field name="transmission"/>
                            <field name="vehicle_type" />
                            <field name="vehicle_type_code"/>
                        </group>
                        <group>

                            <field name="body_class"/>
                            <field name="doors"/>
                            <field name="engine_cylinders"/>
                            <field name="engine_displacement"/>
                            <field name="manufacturer"/>
                            <field name="plant_country"/>
                            <field name="plant_city"/>
                            <field name="trim"/>
                        </group>
                    </group>




                    <!-- SWISS VEHICLE DATA -->
                    <group string="Swiss Registration Data">
                        <group>
                            <field name="issue_place_id"/>
                            <!--                            <field name="issue_date"/>-->
                            <field name="type_code"/>
                        </group>
                        <group>
                            <field name="first_registration"/>
                            <field name="mileage"/>
                            <field name="last_service_date"/>
                        </group>
                    </group>


                    <!-- REFERENCES -->
                    <group string="References">
                        <group>
                            <field name="your_ref"/>
                        </group>
                        <group>
                            <field name="our_ref"/>
                        </group>
                    </group>


                    <!-- PHOTOS -->
                    <notebook>

                        <page string="Vehicle Condition Photos"
                              name="vehicle_photos">
                            <div class="row w-100 m-0 pt-3">
                                <!-- FRONT -->
                                <div class="col-md-4 d-flex flex-column align-items-center mb-4">
                                    <field name="image_front"
                                           widget="image"
                                           options='{"size":[256,256]}'
                                           style="width:256px;height:256px;border:1px solid #dee2e6;border-radius:4px;background:#f8f9fa;object-fit:cover;"/>
                                    <div class="mt-2 fw-bold text-dark">
                                        Front View
                                    </div>
                                </div>


                                <!-- BACK -->

                                <div class="col-md-4 d-flex flex-column align-items-center mb-4">
                                    <field name="image_back"
                                           widget="image"
                                           options='{"size":[256,256]}'
                                           style="width:256px;height:256px;border:1px solid #dee2e6;border-radius:4px;background:#f8f9fa;object-fit:cover;"/>
                                    <div class="mt-2 fw-bold text-dark">
                                        Back View
                                    </div>
                                </div>

                                <!-- SIDE -->

                                <div class="col-md-4 d-flex flex-column align-items-center mb-4">

                                    <field name="image_side"
                                           widget="image"
                                           options='{"size":[256,256]}'
                                           style="width:256px;height:256px;border:1px solid #dee2e6;border-radius:4px;background:#f8f9fa;object-fit:cover;"/>

                                    <div class="mt-2 fw-bold text-dark">
                                        Side View
                                    </div>

                                </div>

                            </div>

                        </page>

                        <page string="Service History">
                            <field name="service_ids">
                                <tree editable="bottom">
                                    <field name="service_date"/>
                                    <field name="description"/>
                                    <field name="cost"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Rental History">
                            <field name="rental_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="total_amount"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>









    <!-- Action for Sell Vehicles -->
    <record id="action_vehicle_sell" model="ir.actions.act_window">
        <field name="name">Vehicles for Sale</field>
        <field name="res_model">vehicle.master</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('vehicle_type','=','sell')]</field>
        <field name="context">{'default_vehicle_type': 'sell'}</field>
        <field name="views" eval="[
            (ref('view_vehicle_sell_tree'), 'tree'),
            (ref('view_vehicle_sell_form'), 'form')
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first vehicle for sale
            </p>
            <p>
                Manage vehicles that are available for sale. Track purchase price,
                selling price, and profit margins.
            </p>
        </field>
    </record>

    <!-- Menu for Sell Vehicles -->
    <menuitem id="menu_vehicle_sell"
              name="Vehicles for Sale"
              parent="menu_vehicle_root"
              action="action_vehicle_sell"
              sequence="10"/>

</odoo>